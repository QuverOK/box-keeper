
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  storages     Storage[]
  createdAt    DateTime  @default(now())
}

model Storage {
  id         String   @id @default(cuid())
  name       String
  roomWidth  Float
  roomDepth  Float
  roomHeight Float
  gridSizeX  Int      @default(5)
  gridSizeY  Int      @default(4)
  gridSizeZ  Int      @default(3)
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  boxes      Box[]
  partitions Partition[]
  layoutLabels LayoutLabel[]
  createdAt  DateTime @default(now())
}

model Partition {
  id        String   @id @default(cuid())
  storageId String
  storage   Storage  @relation(fields: [storageId], references: [id], onDelete: Cascade)
  x         Float
  y         Float
  z         Float
  width     Float
  depth     Float
  height    Float
  label     String?
  createdAt DateTime @default(now())
}

model LayoutLabel {
  id        String   @id @default(cuid())
  storageId String
  storage   Storage  @relation(fields: [storageId], references: [id], onDelete: Cascade)
  x         Float
  y         Float
  text      String
  fontSize  Int      @default(12)
  createdAt DateTime @default(now())
}

model Box {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#e0f2fe")
  qrCode    String   @unique
  sizeW     Float
  sizeD     Float
  sizeH     Float
  posX      Float?
  posY      Float?
  posZ      Float?
  storageId String
  storage   Storage  @relation(fields: [storageId], references: [id], onDelete: Cascade)
  items     Item[]
  createdAt DateTime @default(now())
}

model Item {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  photo       String?
  boxId       String
  box         Box      @relation(fields: [boxId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
