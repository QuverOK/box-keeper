DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boxkeeper?schema=public"
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="7d"
PORT=4000

# Optional: comma-separated origins for CORS (Docker dev uses https://localhost:3000)
# CORS_ORIGIN="http://localhost:3000,https://localhost:3000"

# Docker only: set RUN_SEED=true in docker-compose to seed demo data on start
# RUN_SEED=true
